# API Configuration
# For local development with backend on localhost
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# For testing on physical device, use your machine's local IP
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:8080/api/v1

# API Key (must match backend's app.api-key)
EXPO_PUBLIC_API_KEY=changeme-replace-before-sharing
